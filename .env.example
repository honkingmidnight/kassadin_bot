# Discord Bot Configuration
# Token bota pobrany z Discord Developer Portal (https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Client ID aplikacji bota (znajdziesz w General Information -> Application ID)
CLIENT_ID=your_client_id_here

# ID serwera testowego (Guild ID) - zalecane do lokalnego testowania,
GUILD_ID=your_guild_id_here
